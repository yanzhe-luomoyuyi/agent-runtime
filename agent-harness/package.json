{
  "name": "@agent/harness",
  "version": "0.1.0",
  "description": "A model-driven agent harness: native tool-calling protocol, error recovery/self-healing, context & memory management, and richer control flow (planning, reflection, sub-agents, human-in-the-loop). Runtime-agnostic — it talks to any host (e.g. the durable-agent-runtime) purely through @agent/contracts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testkit": {
      "types": "./dist/testkit/index.d.ts",
      "default": "./dist/testkit/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/demo.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@agent/contracts": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
